# ============================================================
# .env.example — Smarter Dog Grooming
#
# Copy to .env.local and fill in the values for local dev.
# Anything prefixed VITE_ is exposed to the browser at build time;
# never put a private secret behind a VITE_ prefix.
#
# Edge Function secrets (ANTHROPIC_API_KEY, META_ACCESS_TOKEN, etc.)
# are NOT read from this file. Set them with `supabase secrets set`
# so they're only available inside the Deno runtime.
# ============================================================

# ── Browser-visible (Vite) ─────────────────────────────────
# Public URL of your Supabase project (the API endpoint).
VITE_SUPABASE_URL=

# Anon/publishable key. Safe to expose; RLS does the gatekeeping.
VITE_SUPABASE_ANON_KEY=


# ============================================================
# Edge Function secrets — set with `supabase secrets set NAME=value`,
# NOT in this file. Listed here so you know what to provision.
# ============================================================
#
# Required for the WhatsApp AI receptionist:
#
# ANTHROPIC_API_KEY      — Claude API key. Server-side only.
# CLAUDE_MODEL           — defaults to claude-sonnet-4-6.
# AGENT_CALLBACK_SECRET  — shared secret between the pg_net trigger
#                          (migration 027) and the whatsapp-agent
#                          Edge Function. Random, ≥32 chars.
#
# Required for outbound messaging:
#
# META_ACCESS_TOKEN      — WhatsApp Cloud API permanent token.
# META_PHONE_NUMBER_ID   — your sending number's ID.
# SEND_INTERNAL_SECRET   — used by whatsapp-agent for auto-send and
#                          by any service-role caller of whatsapp-send.
#
# Receptionist policy flags (added by migration 038):
#
# AI_ASSISTANT_ENABLED   — kill switch. 'true' (default) | 'false'.
#                          When 'false', the agent skips Claude and
#                          writes a brand-voiced fallback draft tagged
#                          for human handoff so staff still see a row.
# AI_AUTO_SEND_LOW_RISK  — global gate for auto-send. 'false' (default)
#                          | 'true'. Even when 'true', a draft only
#                          auto-sends when the conversation has
#                          auto_send_enabled=true AND the draft is low
#                          risk + handoff-free + in the auto-send intent
#                          allowlist.
# WHATSAPP_SEND_URL      — optional. Defaults to
#                          ${SUPABASE_URL}/functions/v1/whatsapp-send.
